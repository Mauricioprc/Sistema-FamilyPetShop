# ============================================================
# COPIE ESTE ARQUIVO PARA .env E PREENCHA COM SEUS VALORES
# NUNCA compartilhe o .env real!
# ============================================================

# Chave secreta — gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=GERE_UMA_CHAVE_AQUI

# Credenciais do administrador
ADMIN_USERNAME=seu_usuario

# Hash da senha — gere com: python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('SUA_SENHA'))"
ADMIN_PASSWORD_HASH=GERE_O_HASH_AQUI

# Ambiente: development | production
FLASK_ENV=development

# Debug (nunca True em produção)
DEBUG=False

# Nível de log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Rate limiting (memory:// para dev, redis://localhost:6379 para produção)
RATELIMIT_STORAGE_URL=memory://
